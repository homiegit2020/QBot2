BOT_TOKEN=123456:replace-me
# Local default. On Railway, attach a Postgres database and use Railway's DATABASE_URL.
# postgres:// and postgresql:// URLs are converted to postgresql+asyncpg:// automatically.
DATABASE_URL=sqlite+aiosqlite:///./marco_bot.sqlite3

# Comma-separated Telegram numeric user IDs that can approve/reject payments.
ADMIN_IDS=111111111,222222222
ADMIN_REVIEW_CHAT_ID=-1001234567890

# Public ad destinations. Use @username or numeric chat IDs where your bot is admin.
ADS_CHANNEL_ID=@MARCO_P2P
ADS_GROUP_ID=-1001234567891

# Required ad-posting groups. Use numeric IDs for membership checks.
REQUIRED_GROUP_1_ID=-1001234567892
REQUIRED_GROUP_1_LINK=https://t.me/example_group_1
REQUIRED_GROUP_2_ID=-1001234567893
REQUIRED_GROUP_2_LINK=https://t.me/example_group_2

POST_AD_COOLDOWN_SECONDS=10800
TIMEZONE=Asia/Kolkata
SUPPORT_URL=https://t.me/MARCO_Escrow_Chat
BANNER_IMAGE_PATH=

# Optional JSON map. Missing entries fall back to visible CONFIGURE_* placeholders.
# Example:
# DEPOSIT_ADDRESSES_JSON={"USDT":{"BEP20":"Txxxx","TRC20":"Tyyyy"},"BTC":{"BTC":"bc1..."}}
DEPOSIT_ADDRESSES_JSON={}

# Easier direct address variables. These are merged into DEPOSIT_ADDRESSES_JSON automatically.
TRX_ADDRESS=
BNB_ADDRESS=
ETH_ADDRESS=

# Optional chain/scanner API credentials for future auto-verification features.
ETHERSCAN_API_KEY=
INFURA_URL=
INFURA_API_KEY=
TRONGRID_API_KEY=

# Optional Telegram user API credentials. The bot does not need these for normal Bot API polling.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
